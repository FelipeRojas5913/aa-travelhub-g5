{
  "title": "TravelHub — Detección de Token Tampering",
  "uid": "travelhub-intrusion",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Resultados por Escenario",
      "type": "table",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "datasource": {"type": "postgres", "uid": "Postgres"},
      "targets": [
        {
          "rawSql": "SELECT scenario, action_taken, COUNT(*) AS total, MIN(timestamp) AS first_seen, MAX(timestamp) AS last_seen FROM intrusion_log GROUP BY scenario, action_taken ORDER BY first_seen",
          "format": "table"
        }
      ],
      "options": {"sortBy": [{"displayName": "first_seen"}]}
    },
    {
      "id": 2,
      "title": "Doble Canal — JWT OK pero Fingerprint FAIL",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 4},
      "datasource": {"type": "postgres", "uid": "Postgres"},
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM intrusion_log WHERE jti_found_in_db = false OR fingerprint_match = false",
          "format": "table"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "id": 3,
      "title": "Tokens Forjados Detectados",
      "type": "stat",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 4},
      "datasource": {"type": "postgres", "uid": "Postgres"},
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM intrusion_log WHERE action_taken = 'BLOCKED'",
          "format": "table"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "orange"}}}
    },
    {
      "id": 4,
      "title": "Tasa de Detección (%)",
      "type": "stat",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 4},
      "datasource": {"type": "postgres", "uid": "Postgres"},
      "targets": [
        {
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN action_taken = 'BLOCKED' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS value FROM intrusion_log",
          "format": "table"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}, "unit": "percent"}}
    },
    {
      "id": 5,
      "title": "Timeline de Intentos de Intrusión",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "datasource": {"type": "postgres", "uid": "Postgres"},
      "targets": [
        {
          "rawSql": "SELECT $__timeGroupAlias(timestamp, '1m'), scenario, COUNT(*) AS count FROM intrusion_log WHERE $__timeFilter(timestamp) GROUP BY 1, scenario ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "title": "Log de Auditoría Completo",
      "type": "table",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 10},
      "datasource": {"type": "postgres", "uid": "Postgres"},
      "targets": [
        {
          "rawSql": "SELECT timestamp, scenario, jti_presented, jti_found_in_db, fingerprint_match, action_taken, ip_address, details FROM intrusion_log ORDER BY timestamp DESC LIMIT 100",
          "format": "table"
        }
      ]
    }
  ]
}
